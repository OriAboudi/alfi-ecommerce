# Backend Environment Variables

# PostgreSQL Configuration (Local Development)
# Use one of the two approaches below:

# APPROACH 1: Individual connection parameters (for local PostgreSQL)
NODE_ENV=development
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=alfie

# APPROACH 2: PostgreSQL Connection String (for cloud databases like Railway, Hercel, Render)
# Uncomment this line and set it for production
# DATABASE_URL=postgresql://user:password@host:port/database

# Server Configuration
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=https://alfi-ecommerce-ij2i.vercel.app

# Frontend API Configuration
VITE_API_URL=https://alfi-ecommerce-w4u3.vercel.app/api
